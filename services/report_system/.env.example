# SMTP account
# Optional. Relative paths are resolved from the project root.
FUTURES_DATA_DIR=data
BACKUP_DIR=backups
DB_BACKUP_KEEP_DAYS=30
LOG_KEEP_DAYS=60
REPORT_KEEP_DAYS=180

EMAIL_SENDER=demo@example.com
EMAIL_PASSWORD=
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_SSL=true

# Report recipients, separated by comma or semicolon.
REPORT_RECIPIENTS=receiver@example.com
REPORT_CC=

# Keep true until you are ready to send real emails.
REPORT_EMAIL_DRY_RUN=true
REPORT_MAX_ATTACHMENT_SIZE=20971520
REPORT_EMAIL_BATCH_SIZE=1
REPORT_EMAIL_BATCH_INTERVAL_SECONDS=20

PUSHPLUS_ENABLED=false
PUSHPLUS_TOKEN=

# Optional AI analysis. Keep disabled until DEEPSEEK_API_KEY is configured.
AI_ANALYSIS_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_ANALYSIS_TIMEOUT_SECONDS=60
AI_ANALYSIS_MAX_TOKENS=900
